# DCA Keeper - Environment Configuration
# Copy this file to .env and fill in your values

# RPC URL (Fuji testnet or Avalanche mainnet)
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Keeper Private Key (use separate wallet from owner)
PRIVATE_KEY=your_keeper_private_key_here

# Check interval in milliseconds (default: 5 minutes)
CHECK_INTERVAL_MS=300000

# DCA Factory contract address
DCA_FACTORY_ADDRESS=0x1d50d7D9E5bD67E5A5af9dcEd572399478EDac8c

# Gas limit multiplier for transactions (1.2 = 20% buffer)
GAS_LIMIT_MULTIPLIER=1.2

# Minimum AVAX balance required to run keeper (in AVAX)
MIN_AVAX_BALANCE=0.5
