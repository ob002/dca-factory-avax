# DCA Factory Contracts - Environment Configuration
# Copy this file to .env and fill in your values

# Avalanche Mainnet RPC (for fork tests)
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Fuji Testnet RPC
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployer Private Key (DO NOT COMMIT REAL KEY)
# Use a test wallet with limited funds on Fuji testnet
PRIVATE_KEY=your_test_private_key_here

# Snowtrace API Key (for contract verification)
# Get from: https://snowtrace.io/myapikey (sign up free)
SNOWTRACE_API_KEY=

# Optional: CoinMarketCap API key for gas reporting
# COINMARKETCAP_API_KEY=

# Optional: Set to "true" to enable gas reporting in tests
# REPORT_GAS=true
